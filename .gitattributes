# Unity text files - normalize line endings
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf

# Unity scene & asset files
*.unity text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.asset text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.asmdef text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Unity project files
*.Project text eol=lf
*.sln text eol=lf
*.csproj text eol=lf

